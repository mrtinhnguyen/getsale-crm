# ============================================================
# Production .env for SERVER (docker-compose.server.yml)
# Copy to .env on server: cp env.server.example .env
# Do NOT commit real .env with secrets to git.
#
# Required: POSTGRES_PASSWORD, REDIS_PASSWORD, RABBITMQ_PASSWORD, JWT_SECRET,
# JWT_REFRESH_SECRET, INTERNAL_AUTH_SECRET. Without these, docker compose shows
# warnings and services may fail.
# ============================================================

# Database (use strong password in production)
POSTGRES_PASSWORD=your_strong_postgres_password

# Redis (use strong password in production)
REDIS_PASSWORD=your_strong_redis_password

# RabbitMQ: password for user "getsale". docker-compose.server.yml builds
# RABBITMQ_URL=amqp://getsale:${RABBITMQ_PASSWORD}@rabbitmq:5672 for all services.
# Use strong password in production.
RABBITMQ_PASSWORD=your_strong_rabbitmq_password

# JWT (generate strong random secrets for production)
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars

# Internal auth (gateway → backends). Same value on gateway and all backend services.
# Generate: openssl rand -hex 32 . Required in production; do not use dev_internal_auth_secret.
INTERNAL_AUTH_SECRET=your_internal_auth_secret_min_32_chars

# CORS (frontend URL; default used if not set)
CORS_ORIGIN=https://app.getsale.ai

# Optional: shared cookie domain for WebSocket (e.g. .getsale.ai) so token is sent to ws-crm.getsale.ai
COOKIE_DOMAIN=.getsale.ai

# OpenAI (optional; leave empty to disable AI features)
OPENAI_API_KEY=sk-...

# Telegram API (BD Accounts — подключение Telegram аккаунтов; получить на https://my.telegram.org/apps)
# Вариант 1: при деплое через GitHub Actions — добавить секреты TELEGRAM_API_ID и TELEGRAM_API_HASH в репозитории; они записываются в .env на сервере при каждом деплое.
# Вариант 2: задать в .env на сервере (в каталоге с docker-compose.server.yml). После изменения: docker compose -f docker-compose.server.yml up -d --force-recreate bd-accounts-service
TELEGRAM_API_ID=12345
TELEGRAM_API_HASH=your_api_hash_here

# Шифрование сессий BD-аккаунтов (api_hash, session_string). Обязательно для bd-accounts-service, если включено шифрование.
# Должен совпадать на всех инстансах; при смене ключа старые зашифрованные сессии не расшифруются.
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_ENCRYPTION_KEY=your_32_byte_hex_or_long_passphrase

# Stripe (optional; leave empty if not using billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Registry (optional; default: registry.digitalocean.com/regestry-getsale-ai)
# REGISTRY=registry.digitalocean.com/regestry-getsale-ai

# Environment
NODE_ENV=production