# Development Dockerfile for frontend (Next.js).
# Build context: repo root. Requires .dockerignore so frontend/node_modules and frontend/.next
# are not sent to the daemon (keeps image smaller).
# Build: docker build -f docker/frontend/Dockerfile.dev -t getsale-crm-frontend-dev .
FROM node:22-alpine

WORKDIR /app

# su-exec so entrypoint can chown volumes then run as appuser (fixes .next lockfile permission denied)
RUN apk add --no-cache su-exec

# Install deps first (cached unless package*.json change); then copy source (no node_modules thanks to .dockerignore)
COPY frontend/package*.json ./
RUN npm install

COPY frontend/ ./

RUN addgroup -g 1001 -S appgroup && adduser -u 1001 -S appuser -G appgroup
RUN chown -R appuser:appgroup /app

COPY docker/frontend/entrypoint.dev.sh /entrypoint.sh
RUN sed -i 's/\r$//' /entrypoint.sh && chmod +x /entrypoint.sh

EXPOSE 3000
ENTRYPOINT ["/entrypoint.sh"]
CMD ["npm", "run", "dev", "--", "-p", "3000", "-H", "0.0.0.0"]
